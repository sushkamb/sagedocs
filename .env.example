# ForteAI Configuration

# LLM Provider (openai or anthropic)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Default LLM model (gpt-5.2 for full power, gpt-5.2-instant for speed/cost)
LLM_MODEL=gpt-5.2
LLM_MODEL_FAST=gpt-5-mini

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma

# Logging (DEBUG for verbose RAG pipeline tracing, INFO for production)
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8500

# CORS - allowed origins (comma-separated)
CORS_ORIGINS=http://localhost,http://localhost:8080

# Admin dashboard secret key
ADMIN_SECRET_KEY=change-this-to-a-random-string

# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
JWT_SECRET=change-this-jwt-secret
